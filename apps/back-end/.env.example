# Runtime
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=teddy
DATABASE_PASSWORD=teddy
DATABASE_NAME=teddy_open_finance
# Runs TypeORM migrations at boot. Keep true for dev/prod, false for tests.
DATABASE_RUN_MIGRATIONS=true

# JWT — change both secrets in production (use 32+ random chars).
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Logging
# Levels: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug
# Pretty-prints logs in the terminal. Keep false in production (JSON goes to Loki).
LOG_PRETTY=true
LOG_APP_NAME=teddy-backend

# Agent — /agent/chat is disabled when OPENAI_API_KEY is empty.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
