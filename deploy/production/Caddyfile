{
	order rate_limit before reverse_proxy
}

{$APP_DOMAIN} {
	reverse_proxy frontend:80
}

app.digai.chat {
	redir https://{$APP_DOMAIN}{uri} 301
}

{$API_DOMAIN} {
	@chat path /agent/chat
	rate_limit @chat {
		zone chat_per_ip {
			key {client_ip}
			events 10
			window 1m
		}
	}

	rate_limit {
		zone api_per_ip {
			key {client_ip}
			events 120
			window 1m
		}
	}

	reverse_proxy backend-1:3000 backend-2:3000 {
		lb_policy round_robin
		health_uri /healthz
		health_interval 10s
	}
}

{$GRAFANA_DOMAIN} {
	reverse_proxy grafana:3000
}
